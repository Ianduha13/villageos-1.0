# Copy to terraform.tfvars (git-ignored) and adjust locally — NEVER commit the
# real file. Keep these in sync with ../../../.env.example.

# --- Credentials & models (set these) ---
project_name        = "villageos"
postgres_db         = "villageos"
postgres_user       = "village"
postgres_password   = "village"
minio_root_user     = "village"
minio_root_password = "villagepassword"
llm_chat_model      = "llama3.2"
llm_embedding_model = "nomic-embed-text"

