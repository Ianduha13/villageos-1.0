# Copy to .env.local (git-ignored). These mirror the Terraform backend_env so
# the app and worker resolve Postgres/Redis/MinIO/Ollama by container name on
# villageos-network, and by localhost when running outside the stack.

# --- Postgres (Reality Ledger + relational + pgvector) ---
DATABASE_URL=postgresql://village:village@localhost:5432/villageos

# --- Redis (async IA da Vila queue) ---
REDIS_URL=redis://localhost:6379

# --- S3-compatible object storage (proof artifacts) ---
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=proofs
S3_ACCESS_KEY=village
S3_SECRET_KEY=villagepassword

# --- Inference adapter (advisory IA da Vila; never decides) ---
LLM_PROVIDER=local
LLM_BASE_URL=http://localhost:11434
LLM_CHAT_MODEL=llama3.2
LLM_EMBEDDING_MODEL=nomic-embed-text

# --- Session auth ---
AUTH_SECRET=change-me-in-a-real-deployment
