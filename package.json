{
  "name": "villageos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "VillageOS — stewardship infrastructure for a village/hostel arena (first arena: Barra da Lagoa). Reality Ledger + Arena + Stewardship.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "worker": "tsx worker/index.ts",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx db/migrate.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.4",
    "next": "^15.5.19",
    "pg": "^8.13.1",
    "postgres": "^3.4.5",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@testcontainers/postgresql": "^10.16.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.28.1",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.5.19",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "testcontainers": "^10.16.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
